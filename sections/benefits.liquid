{% stylesheet %}
  .benefits {
    padding: 4rem 2rem;
    background-color: white;
  }

  .benefits-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .benefits-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .benefits-header h2 {
    font-size: 2.5rem;
    color: #2D2D2D;
    margin-bottom: 1rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem;
  }

  .benefit-item {
    text-align: center;
    padding: 2rem;
    border-radius: 12px;
    background-color: #F7F3EE;
    transition: all 0.3s ease;
  }

  .benefit-item:hover {
    background-color: #DCCCB8;
    transform: translateY(-4px);
  }

  .benefit-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .benefit-item h3 {
    font-size: 1.3rem;
    color: #2D2D2D;
    margin-bottom: 1rem;
  }

  .benefit-item p {
    font-size: 0.95rem;
    color: #6F6A63;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .benefits-header h2 {
      font-size: 1.8rem;
    }
  }
{% endstylesheet %}

<section class="benefits">
  <div class="benefits-container">
    <div class="benefits-header">
      <h2>Pourquoi Choisir Ninolia ?</h2>
    </div>
    
    <div class="benefits-grid">
      <div class="benefit-item">
        <div class="benefit-icon">👶</div>
        <h3>Pour les Bébés</h3>
        <p>Tous nos produits sont doux, hypoallergéniques et testés dermatologiquement pour la peau sensible de votre bébé.</p>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon">💚</div>
        <h3>Pour les Mamans</h3>
        <p>Des produits conçus pour le bien-être et la sérénité des mères modernes et conscientes.</p>
      </div>
      <div class="benefit-item">
        <div class="benefit-icon">🌍</div>
        <h3>Responsable & Durable</h3>
        <p>Emballages éco-responsables et production éthique pour un avenir meilleur pour nos enfants.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pourquoi Choisir Ninolia"
}
{% endschema %}
