    },
    {
      "type": "textarea",
      "id": "benefit_text_3",
      "label": "Texte Bénéfice 3",
      "default": "Emballages éco-responsables et production éthique pour un avenir meilleur pour nos enfants."
    }
  ]
}
{% endschema %}
