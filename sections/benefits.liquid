      "default": "Tous nos produits sont doux, hypoallergéniques et testés dermatologiquement pour la peau sensible de votre bébé."
    },
    {
      "type": "text",
      "id": "benefit_icon_2",
      "label": "Icône Bénéfice 2",
      "default": "💚"
    },
    {
      "type": "text",
      "id": "benefit_title_2",
      "label": "Titre Bénéfice 2",
      "default": "Pour les Mamans"
    },
    {
      "type": "textarea",
      "id": "benefit_text_2",
      "label": "Texte Bénéfice 2",
      "default": "Des produits conçus pour le bien-être et la sérénité des mères modernes et conscientes."
    },
    {
      "type": "text",
      "id": "benefit_icon_3",
      "label": "Icône Bénéfice 3",
      "default": "🌍"
    },
    {
      "type": "text",
      "id": "benefit_title_3",
      "label": "Titre Bénéfice 3",
