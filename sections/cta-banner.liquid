{% stylesheet %}
  .cta-banner {
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #DCCCB8 0%, #C98F75 100%);
    text-align: center;
  }

  .cta-banner-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-banner h2 {
    font-size: 2rem;
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta-banner p {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
  }

  .cta-banner-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn-primary {
    padding: 14px 36px;
    background-color: white;
    color: #C98F75;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cta-btn-primary:hover {
    transform: translateY(-2px);
  }

  .cta-btn-secondary {
    padding: 14px 36px;
    background-color: transparent;
    color: white;
    border: 2px solid white;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cta-btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 768px) {
    .cta-banner-buttons {
      flex-direction: column;
    }
    
    .cta-btn-primary,
    .cta-btn-secondary {
      width: 100%;
    }
  }
{% endstylesheet %}

<section class="cta-banner">
  <div class="cta-banner-container">
    <h2>Prêt à Découvrir Ninolia?</h2>
    <p>Rejoignez des milliers de parents qui ont choisi Ninolia pour le bien-être de leur bébé.</p>
    <div class="cta-banner-buttons">
      <button class="cta-btn-primary" onclick="window.location.href='/collections/all'">
        Acheter Maintenant
      </button>
      <button class="cta-btn-secondary" onclick="window.location.href='/pages/about'">
        En Savoir Plus
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner"
}
{% endschema %}
