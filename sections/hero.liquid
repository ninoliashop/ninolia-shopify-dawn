{% stylesheet %}
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F7F3EE 0%, rgba(220, 204, 184, 0.3) 100%);
    overflow: hidden;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    color: #2D2D2D;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .hero-content p {
    font-size: 1.25rem;
    color: #6F6A63;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .hero-btn {
    display: inline-block;
    padding: 16px 40px;
    background-color: #C98F75;
    color: white;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(45, 45, 45, 0.12);
    transition: all 0.3s ease;
  }

  .hero-btn:hover {
    background-color: #B8714F;
    box-shadow: 0 8px 24px rgba(45, 45, 45, 0.15);
    transform: translateY(-2px);
  }

  .hero-image {
    position: relative;
    height: 600px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(45, 45, 45, 0.15);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      padding: 2rem;
    }
    
    .hero-content h1 {
      font-size: 2rem;
    }
    
    .hero-image {
      height: 350px;
    }
  }
{% endstylesheet %}

<div class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1>{{ section.settings.hero_title }}</h1>
      <p>{{ section.settings.hero_subtitle }}</p>
      <button class="hero-btn" onclick="window.location.href='{{ section.settings.button_link }}'">
        {{ section.settings.button_text }}
      </button>
    </div>
    <div class="hero-image">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 600 }}" alt="{{ section.settings.hero_title }}" />
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Titre Principal",
      "default": "Bienvenue chez Ninolia"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Sous-titre",
      "default": "Des produits premium pour les bébés et les mamans qui cherchent l'excellence"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du Bouton",
      "default": "Découvrir la Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du Bouton"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image Hero"
    }
  ]
}
{% endschema %}
