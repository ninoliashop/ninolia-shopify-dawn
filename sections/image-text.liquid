{% stylesheet %}
  .image-text {
    padding: 4rem 2rem;
    background-color: #F7F3EE;
  }

  .image-text-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .image-text-image {
    height: 500px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(45, 45, 45, 0.15);
  }

  .image-text-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-text-content h2 {
    font-size: 2.2rem;
    color: #2D2D2D;
    margin-bottom: 1.5rem;
  }

  .image-text-content p {
    font-size: 1rem;
    color: #6F6A63;
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .image-text-cta {
    display: inline-block;
    padding: 12px 32px;
    background-color: #C98F75;
    color: white;
    border-radius: 12px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .image-text-cta:hover {
    background-color: #B8714F;
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .image-text-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .image-text-image {
      height: 300px;
    }
    
    .image-text-content h2 {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

<section class="image-text">
  <div class="image-text-container">
    <div class="image-text-image">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 600 }}" alt="{{ section.settings.title }}" />
      {% endif %}
    </div>
    <div class="image-text-content">
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.text }}</p>
      <button class="image-text-cta" onclick="window.location.href='{{ section.settings.button_link }}'">
        {{ section.settings.button_text }}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + Texte",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Notre Histoire"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Ninolia est née de la passion d'une mère pour offrir des produits de qualité premium à son bébé. Aujourd'hui, nous sommes fiers de servir des milliers de familles à travers le monde."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du Bouton",
      "default": "En Savoir Plus"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du Bouton"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ]
}
{% endschema %}
