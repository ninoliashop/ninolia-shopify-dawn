{% stylesheet %}
  .newsletter {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #DCCCB8 0%, #C98F75 100%);
  }

  .newsletter-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter h2 {
    font-size: 2rem;
    color: white;
    margin-bottom: 1rem;
  }

  .newsletter p {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    background-color: white;
    padding: 8px;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(45, 45, 45, 0.12);
  }

  .newsletter-form input {
    flex: 1;
    border: none;
    padding: 12px 16px;
    font-size: 1rem;
    background-color: transparent;
    outline: none;
    color: #2D2D2D;
  }

  .newsletter-form input::placeholder {
    color: #6F6A63;
  }

  .newsletter-form button {
    padding: 12px 32px;
    background-color: #C98F75;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-form button:hover {
    background-color: #B8714F;
  }

  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
{% endstylesheet %}

<section class="newsletter">
  <div class="newsletter-container">
    <h2>Restez Informée des Nouveautés</h2>
    <p>Inscrivez-vous à notre newsletter pour recevoir des conseils exclusifs et des offres réservées à nos abonnés.</p>
    
    <form class="newsletter-form" method="POST" action="/contact">
      <input type="email" name="email" placeholder="Votre email" required>
      <button type="submit">S'abonner</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter"
}
{% endschema %}
