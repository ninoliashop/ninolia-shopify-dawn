{% stylesheet %}
  .stats {
    padding: 4rem 2rem;
    background-color: white;
  }

  .stats-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .stats-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .stats-header h2 {
    font-size: 2.2rem;
    color: #2D2D2D;
    margin-bottom: 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem;
    background-color: #F7F3EE;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .stat-item:hover {
    background-color: #DCCCB8;
    transform: translateY(-4px);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: #C98F75;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 1rem;
    color: #2D2D2D;
    font-weight: 600;
  }

  .stat-description {
    font-size: 0.85rem;
    color: #6F6A63;
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .stats-header h2 {
      font-size: 1.8rem;
    }
  }
{% endstylesheet %}

<section class="stats">
  <div class="stats-container">
    <div class="stats-header">
      <h2>{{ section.settings.title }}</h2>
    </div>
    
    <div class="stats-grid">
      {% for i in (1..4) %}
        <div class="stat-item">
          <div class="stat-number">{{ section.settings["stat_number_" | append: i] }}</div>
          <div class="stat-label">{{ section.settings["stat_label_" | append: i] }}</div>
          <div class="stat-description">{{ section.settings["stat_description_" | append: i] }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

