{% stylesheet %}
  .stats {
    padding: 4rem 2rem;
    background-color: white;
  }

  .stats-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .stats-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .stats-header h2 {
    font-size: 2.2rem;
    color: #2D2D2D;
    margin-bottom: 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem;
    background-color: #F7F3EE;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .stat-item:hover {
    background-color: #DCCCB8;
    transform: translateY(-4px);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: #C98F75;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 1rem;
    color: #2D2D2D;
    font-weight: 600;
  }

  .stat-description {
    font-size: 0.85rem;
    color: #6F6A63;
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

<section class="stats">
  <div class="stats-container">
    <div class="stats-header">
      <h2>Les Chiffres de Ninolia</h2>
    </div>
    
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-number">50K+</div>
        <div class="stat-label">Clients Satisfaits</div>
        <div class="stat-description">Familles qui nous font confiance</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">98%</div>
        <div class="stat-label">Taux de Satisfaction</div>
        <div class="stat-description">Avis clients vérifiés</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">24h</div>
        <div class="stat-label">Traitement Commande</div>
        <div class="stat-description">Expédition rapide en France</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">Bio & Certifié</div>
        <div class="stat-description">Produits testés dermatologiquement</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Section Statistiques"
}
{% endschema %}
