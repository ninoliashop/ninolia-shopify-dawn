{% stylesheet %}
  .testimonials-slider {
    padding: 4rem 2rem;
    background-color: white;
  }

  .testimonials-slider-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .testimonials-slider-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials-slider-header h2 {
    font-size: 2.5rem;
    color: #2D2D2D;
    margin-bottom: 1rem;
  }

  .slider-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background-color: #F7F3EE;
  }

  .slider {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .slide {
    min-width: 100%;
    padding: 3rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .slide-stars {
    color: #C98F75;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .slide-text {
    font-size: 1.1rem;
    color: #6F6A63;
    line-height: 1.8;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .slide-author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar-slider {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #DCCCB8;
    overflow: hidden;
  }

  .author-avatar-slider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-info-slider h4 {
    font-size: 1.05rem;
    color: #2D2D2D;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .author-info-slider p {
    font-size: 0.9rem;
    color: #6F6A63;
  }

  .slider-controls {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .slider-btn {
    width: 40px;
    height: 40px;
    border: 2px solid #DCCCB8;
    background-color: white;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.2rem;
    color: #C98F75;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slider-btn:hover {
    background-color: #C98F75;
    color: white;
    border-color: #C98F75;
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #DCCCB8;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background-color: #C98F75;
    width: 30px;
    border-radius: 5px;
  }
{% endstylesheet %}

<section class="testimonials-slider">
  <div class="testimonials-slider-container">
    <div class="testimonials-slider-header">
      <h2>{{ section.settings.title }}</h2>
    </div>

    <div class="slider-wrapper">
      <div class="slider" id="testimonialSlider">
        {% for i in (1..3) %}
          <div class="slide">
            <div class="slide-stars">⭐ ⭐ ⭐ ⭐ ⭐</div>
            <p class="slide-text">"{{ section.settings["testimonial_text_" | append: i] }}"</p>
            <div class="slide-author">
              <div class="author-avatar-slider"></div>
              <div class="author-info-slider">
                <h4>{{ section.settings["author_name_" | append: i] }}</h4>
                <p>{{ section.settings["author_title_" | append: i] }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="slider-controls">
      <button class="slider-btn" onclick="moveSlider(-1)">‹</button>
      <button class="slider-btn" onclick="moveSlider(1)">›</button>
    </div>

    <div class="slider-dots" id="dots"></div>
  </div>
</section>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  const totalSlides = slides.length;

  function updateSlider() {
    document.getElementById('testimonialSlider').style.transform = `translateX(-${currentSlide * 100}%)`;
    updateDots();
  }

  function moveSlider(n) {
    currentSlide = (currentSlide + n + totalSlides) % totalSlides;
    updateSlider();
  }

  function updateDots() {
    const dots = document.querySelectorAll('.dot');
    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === currentSlide);
    });
  }

  // Créer les dots
  function createDots() {
    const dotsContainer = document.getElementById('dots');
    for (let i = 0; i < totalSlides; i++) {
      const dot = document.createElement('div');
      dot.classList.add('dot');
      if (i === 0) dot.classList.add('active');
      dot.onclick = () => {
        currentSlide = i;
        updateSlider();
      };
      dotsContainer.appendChild(dot);
    }
  }

  createDots();
  
  // Auto-rotation tous les 5 secondes
  setInterval(() => moveSlider(1), 5000);
</script>

